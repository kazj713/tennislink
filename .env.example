# ============================================
# 基础配置
# ============================================
NODE_ENV=production
NEXT_PUBLIC_DOMAIN=https://your-domain.com

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql://username:password@localhost:5432/tennis_link_production

# ============================================
# 安全密钥
# ============================================
JWT_SECRET=your-jwt-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-32-chars-long

# ============================================
# 支付宝支付配置
# ============================================
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-private-key-here
ALIPAY_PUBLIC_KEY=your-public-key-here
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payments/notify/alipay

# ============================================
# 微信支付配置（可选）
# ============================================
WECHAT_PAY_MCH_ID=your-mch-id
WECHAT_PAY_API_V3_KEY=your-api-v3-key
WECHAT_PAY_APPID=your-wechat-appid
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payments/notify/wechat

# ============================================
# 邮件服务配置（可选）
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@your-domain.com

# ============================================
# 短信服务配置（可选）
# ============================================
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=your-sign-name
SMS_TEMPLATE_CODE=your-template-code

# ============================================
# 阿里云OSS配置（可选）
# ============================================
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=your-bucket-name
OSS_REGION=your-region

# ============================================
# 腾讯云COS配置（可选）
# ============================================
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_BUCKET=your-bucket-name
COS_REGION=your-region

# ============================================
# 种子数据配置
# ============================================
SEED_ADMIN_EMAIL=admin@tennislink.com
SEED_ADMIN_PASSWORD=your-admin-password
