# ============================================
# 基础配置
# ============================================
NODE_ENV=development
NEXT_PUBLIC_DOMAIN=http://localhost:5000

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tennis_link

# ============================================
# 安全密钥
# ============================================
JWT_SECRET=dev-jwt-secret-key-for-local-development
ENCRYPTION_KEY=dev-encryption-key-32-chars-long!!

# ============================================
# 支付宝支付配置（开发环境留空）
# ============================================
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi-sandbox.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=http://localhost:5000/api/payments/notify/alipay

# ============================================
# 微信支付配置（可选）
# ============================================
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_APPID=
WECHAT_PAY_NOTIFY_URL=http://localhost:5000/api/payments/notify/wechat

# ============================================
# 邮件服务配置（可选）
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# ============================================
# 短信服务配置（可选）
# ============================================
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# ============================================
# 阿里云OSS配置（可选）
# ============================================
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=

# ============================================
# 腾讯云COS配置（可选）
# ============================================
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=

# ============================================
# 种子数据配置
# ============================================
SEED_ADMIN_EMAIL=admin@tennislink.com
SEED_ADMIN_PASSWORD=admin123456
